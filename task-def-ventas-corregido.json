{
  "family": "backend-ventas-corregido",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::571440187930:role/LabRole",
  "taskRoleArn": "arn:aws:iam::571440187930:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend-ventas",
      "image": "571440187930.dkr.ecr.us-east-1.amazonaws.com/proyectosemestral-backend-ventas:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-ventas",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}